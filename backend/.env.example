MARKET_CACHE_TTL_SECONDS=60
COIN_CACHE_TTL_SECONDS=60
INSIGHTS_CACHE_TTL_SECONDS=300
NEWS_CACHE_TTL_SECONDS=600
ALERT_CHECK_CRON=*/5 * * * *
ENABLE_SCHEDULER=true
